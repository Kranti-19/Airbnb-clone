
<style>
  #filters {
    display: flex;
    flex-wrap: nowrap;
    align-items: center;
    gap: 1.5rem;
  }

  .filter {
    text-align: center;
    margin-top: 2rem;
    opacity: 0.5;
    text-decoration: none;
    color: black;
  }

  .filter:hover {
    opacity: 1;
    transform: scale(1.1);
    transition: 0.2s;
    cursor: pointer;
  }

  .filter p {
    font-size: 0.8rem;
  }

  .filter.active {
    opacity: 1;
    font-weight: bold;
    border-bottom: 2px solid black;
  }

  .tax-info {
    display: none;
  }

  .tax-toggle {
    border: 1px solid black;
    border-radius: 1rem;
    height: 3.5rem;
    padding: 0.5rem 1rem;
    margin-left: auto;
    display: flex;
    align-items: center;
    white-space: nowrap;
  }

  /* Card Styling */
  .listing-class {
    border-radius: 15px;
    overflow: hidden;
    transition: 0.3s;
  }

  .listing-class:hover {
    transform: scale(1.03);
    box-shadow: 0 8px 20px rgba(0,0,0,0.2);
  }
</style>

<!-- ================= FILTERS ================= -->
<div id="filters">

  <a href="/listings" class="filter <%= !selectedCategory ? 'active' : '' %>">
    <div><i class="fa-solid fa-fire"></i></div>
    <p>Trending</p>
  </a>

  <a href="/listings?category=Rooms" class="filter <%= selectedCategory === 'Rooms' ? 'active' : '' %>">
    <div><i class="fa-solid fa-bed"></i></div>
    <p>Rooms</p>
  </a>

  <a href="/listings?category=Mountains" class="filter <%= selectedCategory === 'Mountains' ? 'active' : '' %>">
    <div><i class="fa-solid fa-mountain"></i></div>
    <p>Mountains</p>
  </a>

  <a href="/listings?category=Castles" class="filter <%= selectedCategory === 'Castles' ? 'active' : '' %>">
    <div><i class="fa-brands fa-fort-awesome"></i></div>
    <p>Castles</p>
  </a>

  <a href="/listings?category=Pools" class="filter <%= selectedCategory === 'Pools' ? 'active' : '' %>">
    <div><i class="fa-solid fa-person-swimming"></i></div>
    <p>Pools</p>
  </a>

  <a href="/listings?category=Camping" class="filter <%= selectedCategory === 'Camping' ? 'active' : '' %>">
    <div><i class="fa-solid fa-campground"></i></div>
    <p>Camping</p>
  </a>

  <a href="/listings?category=Farms" class="filter <%= selectedCategory === 'Farms' ? 'active' : '' %>">
    <div><i class="fa-solid fa-cow"></i></div>
    <p>Farms</p>
  </a>

  <div class="tax-toggle">
    <div class="form-check form-switch">
      <input class="form-check-input" type="checkbox" id="flexSwitchCheckDefault" />
      <label class="form-check-label">
        Display total after taxes
      </label>
    </div>
  </div>

</div>

<!-- ================= SEARCH TEXT ================= -->
<% if (search) { %>
  <div class="mt-3">
    <h5>Showing results for: "<%= search %>"</h5>
  </div>
<% } %>

<!-- ================= LISTINGS ================= -->

<% if (allListings.length === 0) { %>

  <div class="text-center mt-5">
    <h4>No listings found 😔</h4>
    <p>Try different search or filter</p>
  </div>

<% } else { %>

  <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">

    <% for(let listing of allListings) { %>

      <div class="col">
        <a href="/listings/<%= listing._id %>" class="listing-link">
          <div class="card listing-class">

            <img 
              src="<%= listing.image?.url %>" 
              class="card-img-top"
              style="height: 250px; object-fit: cover;"
            />

            <div class="card-body">
              <p class="card-text">
                <b><%= listing.title %></b><br/>
                ₹ <%= listing.price.toLocaleString("en-IN") %> / night
                <i class="tax-info"> +18% GST</i>
              </p>
            </div>

          </div>
        </a>
      </div>

    <% } %>

  </div>

<% } %>

<!-- ================= SCRIPT ================= -->
<script>
  let taxSwitch = document.getElementById("flexSwitchCheckDefault");

  taxSwitch.addEventListener("click", () => {
    let taxInfo = document.getElementsByClassName("tax-info");

    for (let info of taxInfo) {
      info.style.display = info.style.display !== "inline" ? "inline" : "none";
    }
  });
</script>